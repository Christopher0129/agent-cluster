  "assessmentFramework": {
    "dimension1_risingVolume": {
      "name": "上涨放量评估",
      "criteria": {
        "strong": "涨停日成交量较5日均量放大80%以上，或换手率>15%",
        "normal": "涨停日成交量较5日均量放大30%-80%，或换手率8%-15%",
        "weak": "涨停日成交量较5日均量放大<30%，或换手率<8%"
      },
      "scoring": {"strong": 3, "normal": 2, "weak": 1}
    },
    "dimension2_pullbackShrinking": {
      "name": "回调缩量评估",
      "criteria": {
        "healthy": "非涨停日成交量较涨停日萎缩50%以上，且回调幅度<5%",
        "normal": "非涨停日成交量较涨停日萎缩30%-50%，或回调幅度5%-8%",
        "abnormal": "非涨停日成交量萎缩<30%或反而放大，或回调幅度>8%"
      },
      "scoring": {"healthy": 3, "normal": 2, "abnormal": 0}
    },
    "dimension3_distributionCheck": {
      "name": "出货迹象排查",
      "redFlags": [
        "单日长上影线（冲高回落>3%且收阴或长十字星）",
        "巨量阴柱（单日大阴线伴随成交量较5日均量放大100%以上）",
        "涨停反复开板3次以上且尾盘封单弱",
        "龙虎榜显示机构/游资大幅净卖出",
        "高位放量滞涨（换手率>25%但涨幅<5%）"
      ],
      "scoring": {"none": 4, "minor": 2, "major": -5}
    },
    "finalRating": {
      "healthScore": "dimension1 + dimension2 + dimension3",
      "ratingScale": {
        "健康": "8-10分",
        "一般": "5-7分",
        "异常": "<5分"
      }
    }
  },
