        "formula": "=B2*0.25+C2*0.25+D2*0.2+E2*0.2+F2*0.1"
      },
      {
        "cell": "H2",
        "description": "技术面得分",
        "formula": "=IF(H2>=3,100,IF(H2=2,70,IF(H2=1,40,0)))*0.4 + IF(AND(I2>J2,J2>K2),100,IF(AND(I2>J2),60,30))*0.35 + IF(L2>=3,100,IF(L2>=1.5,60,30))*0.25"
      },
      {
        "cell": "M2",
        "description": "催化剂得分",
        "formula": "=VLOOKUP(N2,policy_table,2,FALSE)*0.4 + VLOOKUP(O2,theme_rank_table,2,FALSE)*0.3 + IF(P2<=3,100,IF(P2<=7,60,30))*0.2 + VLOOKUP(Q2,lifecycle_table,2,FALSE)*0.1"
      },
      {
        "cell": "R2",
        "description": "资金面得分",
        "formula": "=IF(S2>0.15,100,IF(S2>0.08,80,IF(S2>0.03,60,30)))*0.4 + VLOOKUP(T2,dragon_tiger_table,2,FALSE)*0.3 + IF(U2>0.05,100,IF(U2>0.03,80,60))*0.2 + IF(V2<30,100,IF(V2<100,70,40))*0.1"
      },
      {
        "cell": "W2",
        "description": "总分计算",
        "formula": "=ROUND(G2*0.3+H2*0.25+M2*0.25+R2*0.2,2)"
      },
      {
        "cell": "X2",
        "description": "概率分层",
        "formula": "=IF(W2>=85,\"S级\",IF(W2>=70,\"A级\",IF(W2>=55,\"B级\",IF(W2>=40,\"C级\",\"D级\"))))"
      }
    ]
  },
  "dataValidation": {
    "rules": [
      {"field": "code", "rule": "正则匹配^[0-9]{6}\\.(SH|SZ|BJ)$", "errorMsg": "代码格式错误"},
      {"field": "totalScore", "rule": "0<=score<=100", "errorMsg": "分数超出有效范围"},
      {"field": "breakdown", "rule": "sum_of_dimensions == 4", "errorMsg": "维度数量不匹配"}
    ]
  },
