  "batchScoringWorkflow": {
    "workflowName": "候选股批量评分流程",
    "steps": [
      {
        "step": 1,
        "name": "数据获取",
        "description": "获取原始行情和基本面数据",
        "dataPoints": [
          "日线行情(开高低收、成交量)",
          "涨停日历(近5日涨停标记)",
          "龙虎榜数据(营业部、买卖金额)",
          "资金流向(主力净流入)",
          "融资融券余额",
          "北向资金持股",
          "公告/新闻事件",
          "所属概念板块"
        ],
        "pythonPseudocode": "# 数据获取模块\ndef fetch_raw_data(stock_list, date):\n    data = {}\n    for code in stock_list:\n        data[code] = {\n            'price': get_daily_quote(code, date),\n            'limit_up_history': get_limit_up_calendar(code, 5),\n            'dragon_tiger': get_dragon_tiger(code, date),\n            'capital_flow': get_capital_flow(code, 5),\n            'margin': get_margin_data(code),\n            'northbound': get_northbound_holding(code),\n            'announcements': get_announcements(code, 7),\n            'concepts': get_concept_sectors(code)\n        }\n    return data"
      },
      {
        "step": 2,
        "name": "指标计算",
        "description": "计算各维度底层指标",
        "calculationLogic": {
          "情绪指标": "基于全市场数据计算E01-E05",
          "技术指标": "计算均线位置、量能比、连板数",
          "催化剂": "NLP处理公告提取事件类型和日期",
          "资金指标": "计算净流入占比、龙虎榜评分"
        },
        "pythonPseudocode": "# 指标计算模块\ndef calculate_indicators(raw_data):\n    indicators = {}\n    for code, data in raw_data.items():\n        indicators[code] = {\n            'emotion': calc_emotion_indicators(data),\n            'technical': calc_technical_indicators(data),\n            'catalyst': calc_catalyst_score(data),\n            'capital': calc_capital_score(data)\n        }\n    return indicators"
      },
      {
        "step": 3,
        "name": "维度评分",
        "description": "将指标映射为0-100维度得分",
        "mappingMethod": "查表法或分段线性函数",
        "pythonPseudocode": "# 维度评分模块\ndef score_dimensions(indicators):\n    scores = {}\n    for code, ind in indicators.items():\n        scores[code] = {\n            'emotion_score': map_to_score(ind['emotion'], emotion_rules),\n            'tech_score': map_to_score(ind['technical'], tech_rules),\n            'catalyst_score': map_to_score(ind['catalyst'], catalyst_rules),\n            'capital_score': map_to_score(ind['capital'], capital_rules)\n        }\n    return scores"
      },
      {
        "step": 4,
        "name": "总分计算与排序",
        "description": "加权求和并排序",
        "pythonPseudocode": "# 总分计算\ndef calculate_total_scores(dimension_scores):\n    results = []\n    for code, scores in dimension_scores.items():\n        total = (scores['emotion_score'] * 0.30 +\n                scores['tech_score'] * 0.25 +\n                scores['catalyst_score'] * 0.25 +\n                scores['capital_score'] * 0.20)\n        results.append({\n            'code': code,\n            'total_score': round(total, 2),\n            'breakdown': scores\n        })\n    return sorted(results, key=lambda x: x['total_score'], reverse=True)"
      },
      {
        "step": 5,
        "name": "风险标签标注",
        "description": "基于风险规则库添加标签",
        "pythonPseudocode": "# 风险标签模块\ndef add_risk_labels(stock_data, scores):\n    for item in scores:\n        code = item['code']\n        item['risk_labels'] = detect_risks(stock_data[code])\n    return scores"
      }
    ]
  },
