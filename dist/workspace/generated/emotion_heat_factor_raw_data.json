  "dataCollectionMethodology": {
    "sectorRanking": {
      "source": "同花顺概念板块数据",
      "method": "统计各概念板块近5个交易日涨停个股数量，按涨停家数降序排列",
      "updateFrequency": "每日收盘后",
      "scoring": "排名前3得10分，4-6得7分，7-10得5分，11-20得3分，20名后得1分"
    },
    "publicOpinion": {
      "gubaDiscussion": {
        "source": "东方财富股吧热榜",
        "metric": "近3日讨论量环比增长率",
        "threshold": {
          "high": ">300%",
          "medium": "150-300%",
          "low": "<150%"
        }
      },
      "xueqiuMention": {
        "source": "雪球网",
        "metric": "近3日提及次数环比增长率"
      },
      "newsMention": {
        "source": "财联社/证券时报",
        "metric": "近3日新闻提及次数"
      },
      "expectationVotes": {
        "source": "东方财富/同花顺连板预期投票",
        "metric": "参与投票人数及看多比例"
      }
    },
    "consecutiveBoards": {
      "currentBoards": "当前已实现连续涨停天数",
      "marketHeightSpace": "市场当前最高连板数",
      "sameLevelCompetitors": "同连板数竞争个股数量",
      "boardExpectationScoreCalculation": "(市场高度空间-当前连板数)/市场高度空间*100 + 同身位竞争系数"
    }
  },
  "riskDisclosure": [
    "情绪热度数据基于公开信息平台采集，可能存在滞后性",
    "股吧讨论量、新闻提及次数等指标受噪声影响较大",
