{
  "framework_metadata": {
    "name": "A股多次涨停概率评分框架V2（四维度版）",
    "version": "2.0",
    "applicable_market": "A股主板/创业板/科创板",
    "prediction_horizon": "未来5个交易日",
    "scoring_scale": "0-100分",
    "total_weight": 100,
    "created_at": "2025-01-13",
    "dimension_weights": {
      "technical_pattern": 30,
      "emotion_resonance": 25,
      "catalyst_events": 25,
      "chip_structure": 20
    }
  },
  "scoring_dimensions": [
    {
      "dimension_id": "D1",
      "dimension_name": "技术形态",
      "weight": 30,
      "weight_pct": "30%",
      "description": "通过K线形态、均线系统、量价关系等技术指标评估股票短期爆发潜力",
      "sub_indicators": [
        {
          "indicator_id": "D1_01",
          "name": "均线多头排列",
          "max_score": 10,
          "scoring_rules": {
            "完美多头排列(Price>MA5>MA10>MA20>MA60)": 10,
            "标准多头排列(Price>MA5>MA10>MA20)": 7,
            "初步多头排列(Price>MA5>MA10)": 4,
            "均线粘合即将发散": 3,
            "均线空头或杂乱": 0
          },
          "calculation_method": "以收盘价与各周期均线位置关系判定",
          "note": "均线角度越大，趋势越强，可额外+1-2分"
        },
        {
          "indicator_id": "D1_02",
          "name": "突破形态强度",
          "max_score": 10,
          "scoring_rules": {
            "突破年线(250日线)且站稳3日": 10,
            "突破前期高点/平台整理": 8,
            "突破近期震荡区间上沿": 6,
            "回踩支撑后反弹": 4,
            "无明显突破形态": 0
          },
          "calculation_method": "对比当前价格与关键阻力位关系",
          "note": "带量突破加分，无量突破减分"
        },
        {
          "indicator_id": "D1_03",
          "name": "量价配合度",
          "max_score": 6,
          "scoring_rules": {
            "涨停且成交量为20日均量3倍以上": 6,
            "涨停且成交量为20日均量2-3倍": 4,
            "涨停且成交量为20日均量1.5-2倍": 3,
            "涨停但量能不足(1-1.5倍)": 1,
            "涨停后缩量调整": 2
          },
          "calculation_method": "当日成交量/20日平均成交量",
          "note": "量价齐升为最佳信号"
        },
        {
          "indicator_id": "D1_04",
          "name": "涨停基因/历史股性",
          "max_score": 4,
          "scoring_rules": {
            "近3个月有3次以上连板记录": 4,
            "近3个月有1-2次连板记录": 3,
            "近6个月有涨停但无连板": 2,
            "近6个月无涨停记录": 0,
            "近1个月涨停次数>3次": "额外+2分(封顶4分)"
          },
          "calculation_method": "统计历史涨停频率和连板能力",
          "note": "股性活跃的股票更容易连续涨停"
        }
      ],
      "interpretation": {
        "25-30分": "技术形态极佳，具备强突破特征",
        "18-24分": "技术形态良好，趋势向上",
        "10-17分": "技术形态一般，需观察",
        "0-9分": "技术形态较差，不宜追涨"
      }
    },
    {
      "dimension_id": "D2",
      "dimension_name": "情绪共振",
      "weight": 25,
      "weight_pct": "25%",
      "description": "评估市场情绪、板块热度、资金关注度等情绪面因素对涨停持续性的影响",
      "sub_indicators": [
        {
          "indicator_id": "D2_01",
          "name": "板块效应强度",
          "max_score": 10,
          "scoring_rules": {
            "所属板块涨停数>15家": 10,
            "所属板块涨停数10-15家": 8,
            "所属板块涨停数5-9家": 6,
            "所属板块涨停数3-4家": 3,
            "板块内仅1-2家涨停": 1,
            "板块效应分级": {
              "板块涨幅>5%": "额外+2分",
              "板块排名市场前3": "额外+2分"
            }
          },
          "calculation_method": "统计同花顺/通达信概念板块当日涨停家数",
          "note": "板块强度是连板的核心驱动力"
        },
        {
          "indicator_id": "D2_02",
          "name": "资金记忆与辨识度",
          "max_score": 6,
          "scoring_rules": {
            "当前市场最高板或板块龙头": 6,
            "板块内人气第二": 4,
            "近5日上过龙虎榜且资金净流入": 4,
            "近5日有涨停但无龙虎榜": 2,
            "市场辨识度低": 0
          },
          "calculation_method": "综合连板高度、龙虎榜数据、市场讨论热度",
          "note": "资金记忆强的股票更容易被接力"
        },
        {
          "indicator_id": "D2_03",
          "name": "龙虎榜资金质量",
          "max_score": 5,
          "scoring_rules": {
            "3家以上顶级游资合力": 5,
            "2家顶级游资或机构+游资": 4,
            "1家顶级游资主导": 3,
            "机构专用席位净买入>30%": 3,
            "散户席位(东财拉萨)为主": -2,
            "知名游资净卖出": -3
          },
          "calculation_method": "分析龙虎榜买卖双方营业部性质",
          "top_tier_seats": ["国泰君安上海江苏路", "兴业证券陕西分公司", "国泰君安南京太平南路", "华鑫证券上海宛平南路"],
          "note": "顶级游资介入是连板重要信号"
        },
        {
          "indicator_id": "D2_04",
          "name": "市场情绪周期位置",
          "max_score": 4,
          "scoring_rules": {
            "市场处于发酵期(最佳参与期)": 4,
            "市场处于启动期": 3,
            "市场处于高潮期(谨慎)": 2,
            "市场处于退潮期": 0
          },
          "cycle_identification": {
            "启动期": "涨停数<50,最高板3-4板",
            "发酵期": "涨停数60-100,最高板5-7板",
            "高潮期": "涨停数>100,最高板>8板",
            "退潮期": "涨停数骤降,高位股A杀"
          },
          "note": "择时比择股更重要"
        }
      ],
      "interpretation": {
        "20-25分": "情绪共振强烈，市场关注度高",
        "14-19分": "情绪配合良好，有资金关注",
        "8-13分": "情绪一般，持续性存疑",
        "0-7分": "情绪不配合，难以连板"
      }
    },
    {
      "dimension_id": "D3",
      "dimension_name": "催化事件",
      "weight": 25,
      "weight_pct": "25%",
      "description": "评估驱动股价上涨的具体事件催化剂，包括政策、业绩、订单等",
      "sub_indicators": [
        {
          "indicator_id": "D3_01",
          "name": "事件重要性",
          "max_score": 12,
          "scoring_rules": {
            "国家级重大政策直接受益": 12,
            "行业级政策利好": 9,
            "重大合同/订单(>年营收50%)": 10,
            "重大技术突破/产品发布": 9,
            "业绩预增>100%或扭亏": 8,
            "区域性政策/次要利好": 5,
            "概念边缘关联": 2,
            "无明确催化剂": 0
          },
          "event_types": {
            "policy": ["国家级政策", "部委级政策", "地方政策"],
            "earnings": ["业绩预告", "业绩快报", "正式财报"],
            "contract": ["重大合同", "中标公告", "订单披露"],
            "technology": ["技术突破", "专利获批", "产品发布"],
            "restructuring": ["并购重组", "借壳上市", "资产注入"]
          },
          "note": "硬催化优于软催化，实质利好优于概念炒作"
        },
        {
          "indicator_id": "D3_02",
          "name": "事件时效性",
          "max_score": 6,
          "scoring_rules": {
            "事件公告后1-2日内": 6,
            "事件公告后3-5日内": 4,
            "事件公告后5-10日": 2,
            "事件公告超过10日": 0,
            "预期事件(未发生但确定性强)": 3
          },
          "calculation_method": "以交易日计算距事件公告日的天数",
          "note": "时效性决定催化剂的边际影响力"
        },
        {
          "indicator_id": "D3_03",
          "name": "标的稀缺性/受益确定性",
          "max_score": 7,
          "scoring_rules": {
            "唯一受益标的或行业绝对龙头": 7,
            "核心受益标的(TOP3)": 5,
            "间接受益/业务占比小": 3,
            "仅概念关联无实质业务": 1,
            "同概念股数量<5家": "额外+2分",
            "同概念股数量>30家": "减2分"
          },
          "calculation_method": "评估公司在事件中的受益程度和标的稀缺性",
          "note": "越稀缺的股票越容易获得资金青睐"
        }
      ],
      "interpretation": {
        "20-25分": "强催化+高时效+稀缺性，大概率连板",
        "15-19分": "中等催化，具备上涨逻辑",
        "8-14分": "催化较弱，需其他因素配合",
        "0-7分": "无明显催化，纯资金博弈"
      }
    },
    {
      "dimension_id": "D4",
      "dimension_name": "筹码结构",
      "weight": 20,
      "weight_pct": "20%",
      "description": "评估流通市值、换手率、套牢盘分布等影响股价上涨阻力的因素",
      "sub_indicators": [
        {
          "indicator_id": "D4_01",
          "name": "流通市值",
          "max_score": 6,
          "scoring_rules": {
            "流通市值<20亿(超小盘)": 6,
            "流通市值20-50亿(小盘)": 5,
            "流通市值50-100亿(中小盘)": 3,
            "流通市值100-200亿(中盘)": 1,
            "流通市值>200亿(大盘)": 0
          },
          "calculation_method": "最新流通股本×当前股价",
          "note": "小市值是连板的必要条件"
        },
        {
          "indicator_id": "D4_02",
          "name": "换手率与活跃度",
          "max_score": 6,
          "scoring_rules": {
            "近5日平均换手率>20%(极度活跃)": 6,
            "近5日平均换手率10-20%(活跃)": 5,
            "近5日平均换手率5-10%(适中)": 4,
            "近5日平均换手率2-5%(偏低)": 2,
            "近5日平均换手率<2%(低迷)": 0,
            "涨停日换手率": {
              "<10%(锁仓良好)": "额外+2分",
              ">40%(筹码松动)": "减2分"
            }
          },
          "calculation_method": "近5日换手率算术平均",
          "note": "适度活跃为佳，过高过低都不利"
        },
        {
          "indicator_id": "D4_03",
          "name": "套牢盘与筹码分布",
          "max_score": 5,
          "scoring_rules": {
            "近期创阶段新高(无套牢盘)": 5,
            "突破前期密集成交区": 4,
            "距前高<15%(即将突破)": 3,
            "上方套牢盘较重(距前高30-50%)": 1,
            "历史高位附近(套牢盘极重)": 0
          },
          "calculation_method": "分析历史成交量分布与当前价格位置",
          "note": "套牢盘是上涨的阻力，突破后变支撑"
        },
        {
          "indicator_id": "D4_04",
          "name": "股东结构与锁定",
          "max_score": 3,
          "scoring_rules": {
            "大股东高比例锁定(实际流通<30%)": 3,
            "前十大流通股东占比>60%": 2,
            "近期无大额解禁/减持计划": 2,
            "存在减持计划但尚未实施": -1,
            "近期有大额解禁": -2
          },
          "calculation_method": "分析F10股东持股数据与解禁日历",
          "note": "避免踩雷解禁或减持"
        }
      ],
      "interpretation": {
        "16-20分": "筹码结构优秀，拉升阻力小",
        "11-15分": "筹码结构良好，具备条件",
        "6-10分": "筹码结构一般，有压力",
        "0-5分": "筹码结构差，难以连板"
      }
    }
  ],
  "scoring_logic": {
    "calculation_method": "四维度加权求和",
    "formula": "总分 = D1得分 + D2得分 + D3得分 + D4得分",
    "adjustment_factors": [
      {
        "factor": "ST股票",
        "adjustment": "基础分×1.1(涨停幅度5%更容易连板)",
        "max_cap": 100
      },
      {
        "factor": "次新股(上市<6个月)",
        "adjustment": "单独评估，筹码结构分权重降低",
        "note": "次新股波动大，适用不同标准"
      },
      {
        "factor": "市场极端行情",
        "adjustment": "±5分",
        "conditions": {
          "大盘单日涨跌>3%": "±5分",
          "千股涨停/跌停": "特殊处理"
        }
      }
    ]
  },
  "tier_classification": {
    "S级(极高概率)": {
      "score_range": "80-100分",
      "description": "多次涨停概率>50%",
      "characteristics": [
        "技术形态突破+板块龙头+硬催化+小市值",
        "四维度均表现优秀",
        "市场情绪和板块效应配合"
      ],
      "action": "重点关注，积极参与"
    },
    "A级(高概率)": {
      "score_range": "65-79分",
      "description": "多次涨停概率30-50%",
      "characteristics": [
        "具备2-3个强维度支撑",
        "无明显短板维度",
        "有催化但时效性或稀缺性稍弱"
      ],
      "action": "积极跟踪，择机参与"
    },
    "B级(中等概率)": {
      "score_range": "45-64分",
      "description": "多次涨停概率15-30%",
      "characteristics": [
        "有1-2个亮点维度",
        "存在明显短板需要观察",
        "需等待情绪或催化进一步明朗"
      ],
      "action": "观察为主，等待信号"
    },
    "C级(低概率)": {
      "score_range": "25-44分",
      "description": "多次涨停概率5-15%",
      "characteristics": [
        "各维度均表现平平",
        "缺乏明确催化或技术形态不佳",
        "仅适合低吸不适合追涨"
      ],
      "action": "谨慎参与或回避"
    },
    "D级(极低概率)": {
      "score_range": "0-24分",
      "description": "多次涨停概率<5%",
      "characteristics": [
        "多维度存在明显缺陷",
        "可能存在重大风险因素",
        "无参与价值"
      ],
      "action": "坚决回避"
    }
  },
  "usage_guidelines": {
    "data_sources": [
      "行情软件：同花顺、东方财富、通达信",
      "龙虎榜：交易所盘后公布",
      "公告信息：巨潮资讯网、交易所官网",
      "财务数据：Wind、Choice金融终端"
    ],
    "update_frequency": "每日收盘后更新技术形态和情绪共振数据",
    "validity_period": "评分有效期为T+1至T+3个交易日",
    "risk_control": [
      "单一股票仓位不超过总资产5%",
      "设置止损位(如跌破5日线或亏损7%)",
      "大盘系统性风险时降低仓位",
      "ST股票和退市风险股不参与"
    ]
  },
  "risk_disclosure": [
    "本评分框架基于历史数据统计，不构成投资建议",
    "股市有风险，投资需谨慎",
    "多次涨停属于高风险投机行为",
    "过往表现不代表未来收益",
    "模型存在失效可能，需结合实际市场情况判断",
    "交易所监管、停牌核查等不可预测因素可能导致连板中断"
  ],
  "disclaimer": "本框架仅供研究和学习使用，不构成任何投资建议。投资者应独立判断并承担投资风险。股市有风险，入市需谨慎。"
}
