{
  "server": {
    "port": 4040
  },
  "cluster": {
    "controller": "gpt54_controller",
    "maxParallel": 3,
    "subordinateMaxParallel": 3,
    "groupLeaderMaxDelegates": 10
  },
  "workspace": {
    "dir": "./workspace"
  },
  "models": {
    "gpt54_controller": {
      "provider": "openai-responses",
      "model": "gpt-5.4",
      "baseUrl": "https://api.openai.com/v1",
      "apiKeyEnv": "OPENAI_API_KEY",
      "reasoning": {
        "effort": "medium"
      },
      "webSearch": true,
      "role": "controller",
      "label": "GPT-5.4 Controller",
      "specialties": [
        "task planning",
        "delegation",
        "synthesis"
      ]
    },
    "gpt53_codex": {
      "provider": "openai-responses",
      "model": "gpt-5.3-codex",
      "baseUrl": "https://api.openai.com/v1",
      "apiKeyEnv": "OPENAI_API_KEY",
      "reasoning": {
        "effort": "medium"
      },
      "webSearch": true,
      "role": "worker",
      "label": "GPT-5.3 Codex",
      "specialties": [
        "coding",
        "debugging",
        "test planning"
      ]
    },
    "kimi25_worker": {
      "provider": "openai-chat",
      "model": "replace-with-your-kimi-2.5-model-id",
      "baseUrl": "https://api.moonshot.cn/v1",
      "apiKeyEnv": "MOONSHOT_API_KEY",
      "role": "worker",
      "label": "Kimi 2.5",
      "specialties": [
        "long context reading",
        "broad analysis",
        "cross-checking"
      ]
    },
    "kimi_code_worker": {
      "provider": "openai-chat",
      "model": "replace-with-your-kimi-code-model-id",
      "baseUrl": "https://api.moonshot.cn/v1",
      "apiKeyEnv": "MOONSHOT_API_KEY",
      "role": "worker",
      "label": "Kimi Code",
      "specialties": [
        "code review",
        "patch suggestions",
        "implementation critique"
      ]
    }
  }
}
